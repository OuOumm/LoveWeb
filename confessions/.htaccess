<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

<FilesMatch "\.(json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
